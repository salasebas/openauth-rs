# Optional: GitHub API token for community stats (higher rate limits).
# Production: set as a Cloudflare Worker secret, not here.
#   wrangler secret put GITHUB_TOKEN
GITHUB_TOKEN=

# Public site URL — baked into the client bundle at build time.
# Production: set in GitHub Actions (deploy workflow) and wrangler.jsonc vars.
NEXT_PUBLIC_URL=http://localhost:3000
